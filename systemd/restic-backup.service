[Unit]
Description=Restic backup
Documentation=https://github.com/restic/restic
After=network-online.target
Wants=network-online.target
ConditionACPower=true

[Service]
Type=oneshot
User=root
Group=root
Environment=GNUPGHOME=/root/.gnupg
ExecStart=/usr/local/bin/restic-ops/bin/backup.sh
Restart=on-failure
RestartSec=1h
NoNewPrivileges=yes
MemoryDenyWriteExecute=yes
PrivateTmp=yes
ProtectSystem=strict
ReadOnlyPaths=/usr/local/bin/restic-ops
SyslogIdentifier=restic-backup
